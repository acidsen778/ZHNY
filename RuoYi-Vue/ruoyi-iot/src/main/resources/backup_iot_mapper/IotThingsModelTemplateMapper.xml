    <sql id="selectIotThingsModelTemplateVo">
        select template_id, template_name, tenant_id, tenant_name, identifier, type, datatype, specs, is_sys, is_Top, is_Monitor, is_readonly, model_order, del_flag, create_by, create_time, update_by, update_time, remark from iot_things_model_template
    </sql>

    <select id="selectIotThingsModelTemplateList" parameterType="IotThingsModelTemplate" resultMap="IotThingsModelTemplateResult">
        <include refid="selectIotThingsModelTemplateVo"/>
        <where>  
            <if test="templateName != null  and templateName != ''"> and template_name like concat('%', #{templateName}, '%')</if>
            <if test="tenantId != null "> and tenant_id = #{tenantId}</if>
            <if test="tenantName != null  and tenantName != ''"> and tenant_name like concat('%', #{tenantName}, '%')</if>
            <if test="identifier != null  and identifier != ''"> and identifier = #{identifier}</if>
            <if test="type != null "> and type = #{type}</if>
            <if test="datatype != null  and datatype != ''"> and datatype = #{datatype}</if>
            <if test="specs != null  and specs != ''"> and specs = #{specs}</if>
            <if test="isSys != null "> and is_sys = #{isSys}</if>
            <if test="isTop != null "> and is_Top = #{isTop}</if>
            <if test="isMonitor != null "> and is_Monitor = #{isMonitor}</if>
            <if test="isReadonly != null "> and is_readonly = #{isReadonly}</if>
            <if test="modelOrder != null "> and model_order = #{modelOrder}</if>
        </where>
    </select>
    
    <select id="selectIotThingsModelTemplateByTemplateId" parameterType="Long" resultMap="IotThingsModelTemplateResult">
        <include refid="selectIotThingsModelTemplateVo"/>
        where template_id = #{templateId}
    </select>

    <insert id="insertIotThingsModelTemplate" parameterType="IotThingsModelTemplate" useGeneratedKeys="true" keyProperty="templateId">
        insert into iot_things_model_template
        <trim prefix="(" suffix=")" suffixOverrides=",">
