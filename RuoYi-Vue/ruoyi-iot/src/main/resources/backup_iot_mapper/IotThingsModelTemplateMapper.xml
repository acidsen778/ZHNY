    </update>

    <delete id="deleteIotThingsModelTemplateByTemplateId" parameterType="Long">
        delete from iot_things_model_template where template_id = #{templateId}
    </delete>

    <delete id="deleteIotThingsModelTemplateByTemplateIds" parameterType="String">
        delete from iot_things_model_template where template_id in 
        <foreach item="templateId" collection="array" open="(" separator="," close=")">
            #{templateId}
        </foreach>
    </delete>
</mapper>